---
import { ACQUISITION_MAILTO } from '../config/site';
---

<section id="acquire" class="bg-[#1A2E26] text-white">
  <div class="max-w-4xl mx-auto px-6 py-20 text-center">
    <div class="max-w-xl mx-auto">
      <div class="inline-block px-4 py-1 bg-white/10 rounded-full text-xs font-medium tracking-wider mb-6">
        PREMIUM ACQUISITION OPPORTUNITY
      </div>

      <h2 class="text-4xl md:text-5xl font-semibold tracking-tighter leading-tight mb-6">
        Own the definitive name in Brazilian wax training.
      </h2>

      <p class="text-xl text-white/70 mb-10">
        brazilianwax.training combines exact-match SEO with a purpose-built .training TLD — a rare strategic asset for
        education brands, academies, and certification providers.
      </p>

      <a
        href={ACQUISITION_MAILTO}
        class="inline-flex items-center justify-center gap-x-3 px-10 py-4 bg-white text-[#1A2E26] hover:bg-[#F0F7F4] font-semibold text-lg rounded-3xl transition-all active:scale-[0.985]"
      >
        <span>Inquire About Acquisition</span>
        <i class="fa-solid fa-envelope"></i>
      </a>

      <p class="mt-8 text-sm text-white/50">Serious inquiries only &bull; sales@desertrich.com</p>
    </div>
  </div>
</section>
