---
import { ACQUISITION_MAILTO } from '../config/site';
---

<nav class="bg-white/95 backdrop-blur-md border-b border-[#D9EDE4] sticky top-0 z-50" id="nav">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between gap-3 h-16 sm:h-20">
      <a href="/" class="flex items-center gap-x-2 group min-w-0">
        <div class="w-8 h-8 sm:w-9 sm:h-9 shrink-0 bg-brand-500 rounded-2xl flex items-center justify-center group-hover:bg-brand-600 transition-colors">
          <span class="text-white text-sm sm:text-lg font-bold tracking-tighter">BW</span>
        </div>
        <div class="min-w-0 truncate">
          <span class="font-semibold text-base sm:text-2xl tracking-tight">brazilianwax</span>
          <span class="font-semibold text-base sm:text-2xl tracking-tight text-brand-500">.training</span>
        </div>
      </a>

      <div class="flex items-center gap-x-2 sm:gap-x-3 shrink-0">
        <a href="#why" class="hidden md:block px-5 py-2 text-sm font-medium text-brand-700 hover:text-brand-900 transition-colors">Why This Domain</a>
        <a href="#curriculum" class="hidden md:block px-5 py-2 text-sm font-medium text-brand-700 hover:text-brand-900 transition-colors">Curriculum</a>
        <a href="#use-cases" class="hidden lg:block px-5 py-2 text-sm font-medium text-brand-700 hover:text-brand-900 transition-colors">Use Cases</a>

        <a
          href={ACQUISITION_MAILTO}
          class="inline-flex items-center justify-center px-3.5 sm:px-7 py-2 sm:py-2.5 bg-brand-500 hover:bg-brand-600 text-white text-xs sm:text-sm font-semibold rounded-2xl transition-all active:scale-[0.985] whitespace-nowrap"
        >
          <span class="sm:hidden">Inquire</span>
          <span class="hidden sm:inline">Inquire to Acquire</span>
        </a>
      </div>
    </div>
  </div>
</nav>
