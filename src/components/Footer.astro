---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
---

<footer class="bg-white border-t border-[#D9EDE4]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <!-- Sophisticated Domain Acquisition CTA -->
    <div class="relative overflow-hidden rounded-3xl border border-brand-500/25 bg-gradient-to-br from-white via-[#F0F7F4] to-brand-50/60 p-8 sm:p-12 mb-12">
      <div
        class="absolute -top-24 -right-24 w-64 h-64 rounded-full bg-brand-500/10 blur-3xl pointer-events-none"
        aria-hidden="true"
      ></div>
      <div
        class="absolute -bottom-24 -left-24 w-64 h-64 rounded-full bg-brand-300/10 blur-3xl pointer-events-none"
        aria-hidden="true"
      ></div>

      <div class="relative z-10 grid lg:grid-cols-[1.2fr_0.8fr] gap-10 items-center">
        <div>
          <p class="text-xs uppercase tracking-[3px] text-brand-500 font-extrabold mb-4">
            Domain Available for Acquisition
          </p>
          <h2 class="font-display text-3xl sm:text-4xl tracking-tight text-[#1A2E26] mb-4">
            brazilianwax.training — A Category-Defining Digital Asset
          </h2>
          <p class="text-[#3D5A4F] max-w-xl leading-relaxed">
            Positioned at the intersection of high-demand Brazilian wax education and premium digital identity, this
            domain is a rare strategic asset. Serious buyers may inquire for pricing, transfer logistics, and escrow
            options.
          </p>
        </div>

        <div
          class="rounded-2xl p-6 sm:p-8 border border-[#D9EDE4] bg-white/80"
          style="backdrop-filter: blur(22px);"
        >
          <p class="text-xs uppercase tracking-[2px] text-[#5C7A6E] font-semibold mb-2">Acquisition Contact</p>
          <a
            href={ACQUISITION_MAILTO}
            class="block text-2xl sm:text-3xl font-display text-brand-500 hover:text-brand-600 transition-colors break-all"
          >
            {SITE.email}
          </a>
          <a
            href={ACQUISITION_MAILTO}
            class="mt-6 inline-flex w-full items-center justify-center gap-x-3 px-6 py-4 bg-brand-500 hover:bg-brand-600 text-white font-extrabold rounded-2xl transition-all active:scale-[0.985]"
          >
            <span>Inquire About Acquisition</span>
            <i class="fa-solid fa-arrow-right"></i>
          </a>
          <p class="mt-4 text-[11px] text-[#5C7A6E] text-center tracking-wide">
            Confidential inquiries &bull; Response within 24 hours
          </p>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="text-xs text-[#5C7A6E] leading-relaxed max-w-4xl mb-10">
      This website is for demonstration and informational purposes only. It does not constitute an offer of services, a
      commitment to deploy, or a guarantee of outcomes. All statistics, projections, and references to specific
      technologies are based on publicly available information as of July 5, 2026 and are subject to change.
    </p>

    <!-- Bottom bar -->
    <div
      class="pt-8 border-t border-[#D9EDE4] text-xs text-[#5C7A6E] flex flex-col md:flex-row gap-y-4 items-center justify-between"
    >
      <div>&copy; 2026 brazilianwax.training. All rights reserved.</div>
      <div class="flex items-center gap-x-5">
        <span>Premium domain listing by owner</span>
      </div>
    </div>
  </div>
</footer>
