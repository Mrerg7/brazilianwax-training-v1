---
import { ACQUISITION_MAILTO, OG_IMAGE } from '../config/site';
---

<header>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-12 sm:pt-16 pb-8 sm:pb-10">
    <div class="text-center max-w-3xl mx-auto">
      <div class="inline-flex items-center justify-center mb-5 sm:mb-6">
        <div class="modern-pill flex items-center gap-x-2 px-3 sm:px-4 py-1.5 rounded-2xl text-[10px] sm:text-xs font-bold tracking-[0.5px] sm:tracking-[1px] text-center">
          <i class="fa-solid fa-graduation-cap fa-xs shrink-0"></i>
          <span>TRAINING &bull; CERTIFICATION &bull; .TRAINING TLD</span>
        </div>
      </div>

      <h1 class="domain-hero tracking-tighter mb-4 break-words">
        brazilianwax<span class="text-brand-500">.training</span>
      </h1>

      <p class="text-lg sm:text-xl md:text-2xl font-semibold tracking-tight text-brand-800 mb-4 sm:mb-5 text-balance">
        The authoritative domain for professional Brazilian wax education and certification.
      </p>

      <p class="text-base sm:text-lg text-[#3D5A4F] mb-8 sm:mb-10 text-balance">
        Exact-match keywords paired with a purpose-built .training extension — positioned for academies, online courses, and salon certification programs worldwide.
      </p>

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:gap-4">
        <a
          href={ACQUISITION_MAILTO}
          class="group inline-flex items-center justify-center gap-x-3 px-6 sm:px-9 py-3.5 sm:py-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold text-base sm:text-lg rounded-3xl transition-all active:scale-[0.985] shadow-lg shadow-brand-500/20"
        >
          <span>Inquire to Acquire</span>
          <i class="fa-solid fa-arrow-right group-hover:translate-x-0.5 transition-transform"></i>
        </a>

        <a
          href="#why"
          class="inline-flex items-center justify-center px-6 sm:px-8 py-3.5 sm:py-4 border border-[#B3DBC9] hover:bg-white text-brand-700 font-semibold text-base sm:text-lg rounded-3xl transition-all"
        >
          Explore the Opportunity
        </a>
      </div>
    </div>
  </div>

  <figure class="w-full">
    <img
      src={OG_IMAGE}
      alt="Professional Brazilian wax training — demonstration imagery"
      width="1200"
      height="630"
      loading="eager"
      decoding="async"
      class="w-full h-auto object-cover object-center aspect-[16/9] sm:aspect-[21/9] max-h-[300px] sm:max-h-[420px] md:max-h-[520px]"
    />
  </figure>
</header>
