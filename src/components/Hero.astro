---
import { ACQUISITION_MAILTO, OG_IMAGE } from '../config/site';
---

<header class="max-w-6xl mx-auto px-6 pt-16 pb-12 md:pt-20 md:pb-16">
  <div class="grid lg:grid-cols-2 gap-12 items-center">
    <div class="text-center lg:text-left">
      <div class="inline-flex items-center gap-x-2 mb-6">
        <div class="modern-pill flex items-center gap-x-2 px-4 py-1.5 rounded-2xl text-xs font-bold tracking-[1px]">
          <i class="fa-solid fa-graduation-cap fa-xs"></i>
          <span>TRAINING • CERTIFICATION • .TRAINING TLD</span>
        </div>
      </div>

      <h1 class="domain-hero tracking-tighter mb-4">
        brazilianwax<span class="text-brand-500">.training</span>
      </h1>

      <p class="max-w-xl mx-auto lg:mx-0 text-xl md:text-2xl font-semibold tracking-tight text-brand-800 mb-5">
        The authoritative domain for professional Brazilian wax education and certification.
      </p>

      <p class="max-w-lg mx-auto lg:mx-0 text-lg text-[#3D5A4F] mb-10">
        Exact-match keywords paired with a purpose-built .training extension — positioned for academies, online courses, and salon certification programs worldwide.
      </p>

      <div class="flex flex-col sm:flex-row items-center lg:items-start justify-center lg:justify-start gap-4">
        <a
          href={ACQUISITION_MAILTO}
          class="group inline-flex items-center justify-center gap-x-3 px-9 py-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold text-lg rounded-3xl transition-all active:scale-[0.985] shadow-lg shadow-brand-500/20"
        >
          <span>Inquire to Acquire</span>
          <i class="fa-solid fa-arrow-right group-hover:translate-x-0.5 transition-transform"></i>
        </a>

        <a
          href="#why"
          class="inline-flex items-center justify-center px-8 py-4 border border-[#B3DBC9] hover:bg-white text-brand-700 font-semibold text-lg rounded-3xl transition-all"
        >
          Explore the Opportunity
        </a>
      </div>
    </div>

    <div class="relative">
      <div
        class="absolute -inset-4 bg-gradient-to-br from-brand-200/40 to-brand-500/10 rounded-[2rem] blur-2xl pointer-events-none"
        aria-hidden="true"
      ></div>
      <img
        src={OG_IMAGE}
        alt="Professional Brazilian wax training — demonstration imagery"
        width="1200"
        height="630"
        loading="eager"
        decoding="async"
        class="relative w-full rounded-3xl hero-image-glow object-cover aspect-[16/10]"
      />
      <div class="absolute bottom-4 left-4 right-4 sm:left-auto sm:right-4 sm:w-auto">
        <div class="inline-flex items-center gap-x-2 px-4 py-2 bg-white/90 backdrop-blur-sm rounded-2xl text-xs font-semibold text-brand-700 border border-brand-100">
          <i class="fa-solid fa-cloud text-brand-500"></i>
          <span>Delivered via Cloudflare Images CDN</span>
        </div>
      </div>
    </div>
  </div>
</header>
